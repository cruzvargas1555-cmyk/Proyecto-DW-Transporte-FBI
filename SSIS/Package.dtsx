       DATEPART(MONTH, t.Fecha) AS Mes,
       DATEPART(WEEK, t.Fecha) AS Semana, 
       DATEPART(DAY, t.Fecha) AS Dia
FROM oltp_DW_TRANSPORTE_FBI.dbo.DimTiempo t;</property>
